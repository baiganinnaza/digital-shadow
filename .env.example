# PostgreSQL
POSTGRES_USER=shadow
POSTGRES_PASSWORD=shadow
POSTGRES_DB=digital_shadow

# Neo4j
NEO4J_AUTH=neo4j/shadowpass
NEO4J_USER=neo4j
NEO4J_PASSWORD=shadowpass

# Redis
REDIS_URL=redis://redis:6379/0

# App
USE_LOCAL_LLM=false
COLLECT_INTERVAL_SEC=60
SEED_FILE_PATH=data/seed_posts.jsonl
WALLET_BLACKLIST_PATH=data/wallet_blacklist.txt
MODEL_PATH=ml/models/clf.joblib

# Public source collectors (set USE_PUBLIC_SOURCES=true to enable)
USE_PUBLIC_SOURCES=false

# Telegram — get API_ID and API_HASH at https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_CHANNELS=@channel1,@channel2   # public channel usernames to monitor
TG_SESSION_PATH=data/tg_session
TG_LOOKBACK_HOURS=24

# OLX.kz — keywords to search (comma-separated, Russian)
OLX_KEYWORDS=вейп,жижа,испаритель,алкоголь оптом,дроп,курьер анон,нал доставка
